# Postgres connection string used by the web app, worker, and migrations.
DATABASE_URL=postgres://korepush:korepush@localhost:5432/korepush

# Better Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM key for env-var encryption — generate the same way.
ENCRYPTION_KEY=

# Internal Kubernetes Service URL of the image registry the worker pushes to.
REGISTRY_URL=registry.korepush-system.svc.cluster.local:5000

# Namespace the platform itself runs in (Postgres, registry, web, worker).
PLATFORM_NAMESPACE=korepush-system

# Optional: ClusterIssuer name for cert-manager (omit for HTTP-only).
# CERT_ISSUER=letsencrypt-prod

# Optional: override the Ingress class. Defaults to traefik (K3s built-in).
# INGRESS_CLASS=traefik

# Optional: override the BuildKit image used for build Jobs.
# Default is moby/buildkit:v0.18.2-rootless.
# BUILD_IMAGE=moby/buildkit:v0.18.2-rootless
